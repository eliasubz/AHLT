# Copy to ``FROZEN_CONFIG.env`` after you pick the best **devel** setup (no further tuning on **test**).
# ``run_test_once.sh`` and ``llm-NERC.py`` can ``source`` this file on the cluster.

# --- model cache (set on Slurm to scratch) ---
# export HF_HOME=/scratch/$USER/hf_cache
# export LLM_MODEL_ROOT=/scratch/$USER/hf_models

# --- wrapper / Slurm driver ---
export LLM_NERC_STRATEGY=fewshot
# export LLM_NERC_STRATEGY=finetune

export LLM_NERC_MODEL=llama32B3
# export LLM_NERC_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Use an absolute path to the prompt JSON you froze (example: .../1.3.NERC-LLM/bin/prompts01.json).
# export LLM_NERC_PROMPTS=/abs/path/to/Labs/code/1.3.NERC-LLM/bin/prompts01.json

export LLM_NERC_FEW_SHOT=3
export LLM_NERC_FS_TRAIN=train
export LLM_NERC_QUANT=1

# Fine-tune only: basename of the adapter directory under ``models/`` (see ``finetune-train.py`` output).
# export LLM_NERC_FT_WEIGHTS=FT-llama32B3-quant.weights
